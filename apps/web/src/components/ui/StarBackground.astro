---
// StarBackground.astro — Fondo de estrellas animadas optimizado para rendimiento
// Usa @tsparticles/slim: sin links, sin hover, 30fps, soporte prefers-reduced-motion
---

<div id="tsparticles" aria-hidden="true"></div>

<script>
  import { tsParticles } from '@tsparticles/engine';
  import { loadSlim } from '@tsparticles/slim';

  (async () => {
    await loadSlim(tsParticles);

    const prefersReducedMotion = window.matchMedia(
      '(prefers-reduced-motion: reduce)'
    ).matches;

    await tsParticles.load({
      id: 'tsparticles',
      options: {
        background: { color: { value: '#000000' } },
        // 30fps: las estrellas apenas se mueven, imperceptible vs 60fps
        fpsLimit: 30,
        // Sin interactividad = sin event listeners de mouse = ganancia de perf
        interactivity: {
          detectsOn: 'window',
          events: {
            onHover: { enable: false },
            onClick: { enable: false },
            resize: { enable: true },
          },
        },
        particles: {
          // Blanco puro + tonos liláceos suaves para coherencia con la marca
          color: { value: ['#ffffff', '#e2e8f0', '#a5b4fc', '#c7d2fe'] },
          // Sin links: elimina el cálculo O(n²) de distancias entre partículas
          links: { enable: false },
          move: {
            enable: !prefersReducedMotion,
            speed: 0.18,        // deriva muy lenta, como el espacio
            random: true,
            direction: 'none',
            straight: false,
            outModes: { default: 'out' },
          },
          number: {
            // 250 partículas base para un cielo estrellado denso y llamativo
            value: 250,
            density: { enable: true, area: 900 },
          },
          opacity: {
            value: { min: 0.1, max: 0.85 },
            animation: {
              enable: !prefersReducedMotion,
              speed: 0.4,       // titileo suave
              sync: false,
            },
          },
          shape: { type: 'circle' },
          size: {
            // Mezcla de estrellas pequeñas y puntos microscópicos
            value: { min: 0.3, max: 2.2 },
          },
        },
        detectRetina: true,
      },
    });
  })();
</script>

<style>
  #tsparticles {
    position: fixed;
    inset: 0;
    z-index: 0;
    /* pointer-events: none evita que el canvas capture clicks/mouse,
       mejorando rendimiento y usabilidad del contenido encima */
    pointer-events: none;
  }
</style>
