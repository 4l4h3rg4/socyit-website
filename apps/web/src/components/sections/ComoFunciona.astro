---
// ComoFunciona.astro — Timeline vertical con 4 pasos
import { Icon } from 'astro-icon/components';

const pasos = [
  {
    numero: '01',
    titulo: 'Únete a tu división',
    descripcion: 'Elige la rama que más te apasiona: Robótica, Ciber, Software o Videojuegos.',
    icono: 'lucide:telescope',
    colorVar: '--primary',
  },
  {
    numero: '02',
    titulo: 'Colabora entre ramas',
    descripcion: 'Las mejores ideas nacen en la intersección. Conecta con otras divisiones.',
    icono: 'lucide:handshake',
    colorVar: '--robotica',
  },
  {
    numero: '03',
    titulo: 'Construye proyectos reales',
    descripcion: 'Convertí ideas en código, hardware o arte. Proyectos con impacto real.',
    icono: 'lucide:zap',
    colorVar: '--software',
  },
  {
    numero: '04',
    titulo: 'Despegamos juntos',
    descripcion: 'Visibilidad, red de contactos, crecimiento profesional. Todos ganamos.',
    icono: 'lucide:rocket',
    colorVar: '--videojuegos',
  },
];
---

<section class="como-funciona">
  <div class="container">
    <!-- .reveal eliminado: GSAP maneja la entrada de header y pasos -->
    <div class="como__header">
      <span class="section-tag">// PROCESO</span>
      <h2 class="como__title">&gt; ¿Cómo funciona?_</h2>
    </div>

    <div class="como__timeline">
      <!-- Línea vertical conectora — se dibuja con scaleY via GSAP -->
      <div class="como__connector" aria-hidden="true"></div>

      {pasos.map((paso) => (
        <div class="como__step">
          <!-- Ícono cuadrado -->
          <div class="como__step-icon" style={`border-color: var(${paso.colorVar})`}>
            <Icon name={paso.icono} style={`color: var(${paso.colorVar})`} />
          </div>

          <!-- Contenido -->
          <div class="como__step-content">
            <div class="como__step-num">{paso.numero}</div>
            <h3 class="como__step-title">{paso.titulo}</h3>
            <p class="como__step-desc">{paso.descripcion}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  // ---- GSAP: connector line draw + steps cascade ----
  import { gsap, ScrollTrigger, withMotion } from '../../lib/gsap';

  withMotion(() => {
    gsap.set('.como__header',    { autoAlpha: 0, y: 25 });
    // scaleY:0 + transformOrigin top = la línea "se dibuja" de arriba hacia abajo
    gsap.set('.como__connector', { scaleY: 0, transformOrigin: 'top center' });
    gsap.set('.como__step',      { autoAlpha: 0, x: 35 });

    ScrollTrigger.create({
      trigger: '.como__header',
      start: 'top 80%',
      once: true,
      onEnter: () => {
        const tl = gsap.timeline();

        tl.to('.como__header',    { autoAlpha: 1, y: 0, duration: 0.5 })
          // Conector se dibuja de arriba hacia abajo mientras aparecen los pasos
          .to('.como__connector', { scaleY: 1, duration: 0.9, ease: 'power1.inOut' }, '-=0.2')
          // Pasos entran desde la derecha en cascada
          .to('.como__step', {
            autoAlpha: 1,
            x: 0,
            stagger: 0.15,
            duration: 0.5,
          }, '-=0.65');
      },
    });
  });
</script>

<style>
  .como-funciona {
    position: relative;
    z-index: 10;
  }

  .como__header {
    margin-bottom: 3rem;
  }

  .como__title {
    font-family: var(--font-pixel);
    font-size: clamp(1.08rem, 2.5vw, 1.2rem);
    margin-top: 0.25rem;
  }

  /* ---- Timeline ---- */
  .como__timeline {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    padding-left: 3rem;
  }

  /* Línea conectora vertical */
  .como__connector {
    position: absolute;
    left: 19px;
    top: 20px;
    bottom: 20px;
    width: 2px;
    background: linear-gradient(
      to bottom,
      var(--primary),
      var(--software),
      var(--robotica),
      var(--videojuegos)
    );
    opacity: 0.4;
  }

  /* ---- Paso ---- */
  .como__step {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    position: relative;
  }

  /* Ícono cuadrado */
  .como__step-icon {
    position: absolute;
    left: -3rem;
    top: 0;
    width: 40px;
    height: 40px;
    background: var(--bg-card);
    border: 2px solid var(--primary);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    z-index: 1;
  }

  .como__step-icon svg {
    width: 18px;
    height: 18px;
  }

  /* Contenido del paso */
  .como__step-content {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-left: 3px solid var(--primary);
    padding: 1.25rem 1.5rem;
    flex: 1;
    transition: border-color 0.2s, background 0.2s;
  }

  .como__step-content:hover {
    background: var(--bg-card-hover);
  }

  /* Número */
  .como__step-num {
    font-family: var(--font-pixel);
    font-size: 0.61rem;
    color: var(--text-dim);
    letter-spacing: 0.1em;
    margin-bottom: 0.35rem;
  }

  /* Título */
  .como__step-title {
    font-family: var(--font-pixel);
    font-size: 0.81rem;
    color: var(--text);
    margin-bottom: 0.5rem;
    line-height: 1.5;
  }

  /* Descripción */
  .como__step-desc {
    font-family: var(--font-mono);
    font-size: 1.11rem;
    color: var(--text-muted);
    line-height: 1.7;
  }

  /* Colores del borde por paso */
  .como__step:nth-child(2) .como__step-content { border-left-color: var(--robotica); }
  .como__step:nth-child(3) .como__step-content { border-left-color: var(--software); }
  .como__step:nth-child(4) .como__step-content { border-left-color: var(--ciber); }
  .como__step:nth-child(5) .como__step-content { border-left-color: var(--videojuegos); }

  /* ---- Responsive ---- */
  @media (max-width: 520px) {
    .como__timeline {
      padding-left: 2.5rem;
    }

    .como__step-icon {
      left: -2.5rem;
      width: 34px;
      height: 34px;
    }

    .como__step-icon svg {
      width: 15px;
      height: 15px;
    }
  }
</style>
