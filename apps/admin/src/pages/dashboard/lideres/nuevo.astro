---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { createAdminClient } from '../../../lib/supabase';

const supabase = createAdminClient(Astro);
const { data: divisiones } = await supabase
  .from('divisiones')
  .select('id, nombre')
  .order('orden');
---

<AdminLayout title="Nuevo Líder" activePage="lideres">
  <div class="admin-topbar">
    <h1>Nuevo Líder</h1>
    <a href="/dashboard/lideres" class="btn btn--ghost">[ Volver ]</a>
  </div>

  <form class="admin-form" id="form-nuevo">
    <div class="admin-form__group">
      <label class="admin-form__label" for="division_id">División *</label>
      <div class="nes-select">
        <select id="division_id" name="division_id" required>
          <option value="">Seleccionar...</option>
          {divisiones?.map(d => (
            <option value={d.id}>{d.nombre}</option>
          ))}
        </select>
      </div>
    </div>

    <div class="admin-form__group">
      <label class="admin-form__label" for="nombre">Nombre *</label>
      <input id="nombre" name="nombre" type="text" class="nes-input" required />
    </div>

    <div class="admin-form__group">
      <label class="admin-form__label" for="rol">Rol *</label>
      <input id="rol" name="rol" type="text" class="nes-input" required
        placeholder="ej: Líder de División" />
    </div>

    <div class="admin-form__group">
      <label class="admin-form__label" for="contexto">Contexto</label>
      <textarea id="contexto" name="contexto" class="nes-textarea" rows="3"></textarea>
    </div>

    <div class="admin-form__group">
      <label class="admin-form__label" for="foto_url">URL Foto</label>
      <input id="foto_url" name="foto_url" type="url" class="nes-input" />
    </div>

    <div class="admin-form__group">
      <label class="admin-form__label" for="github_url">GitHub URL</label>
      <input id="github_url" name="github_url" type="url" class="nes-input" />
    </div>

    <div class="admin-form__group">
      <label class="admin-form__label" for="linkedin_url">LinkedIn URL</label>
      <input id="linkedin_url" name="linkedin_url" type="url" class="nes-input" />
    </div>

    <p id="form-error" style="display:none; font-family:var(--font-pixel); font-size:0.6rem; color:var(--danger);"></p>

    <div class="admin-form__actions">
      <button type="submit" class="btn btn--primary">[ Crear Líder ]</button>
      <a href="/dashboard/lideres" class="btn btn--ghost">Cancelar</a>
    </div>
  </form>

  <script>
    document.getElementById('form-nuevo')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target as HTMLFormElement;
      const errEl = document.getElementById('form-error') as HTMLElement;
      errEl.style.display = 'none';

      const data = new FormData(form);
      const body: Record<string, unknown> = {};
      for (const [k, v] of data.entries()) {
        body[k] = v || null;
      }

      const res = await fetch('/api/lideres', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });

      if (res.ok) {
        window.location.href = '/dashboard/lideres';
      } else {
        const json = await res.json().catch(() => ({}));
        errEl.textContent = json.error ?? 'Error al crear el líder.';
        errEl.style.display = 'block';
      }
    });
  </script>
</AdminLayout>
