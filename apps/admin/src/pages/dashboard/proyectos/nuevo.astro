---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { createAdminClient } from '../../../lib/supabase';

const supabase = createAdminClient(Astro);
const { data: divisiones } = await supabase.from('divisiones').select('id, nombre').order('orden');
---

<AdminLayout title="Nuevo Proyecto" activePage="proyectos">
  <div class="admin-topbar">
    <h1>Nuevo Proyecto</h1>
    <a href="/dashboard/proyectos" class="btn btn--ghost">[ Volver ]</a>
  </div>

  <form class="admin-form" id="form-nuevo">
    <div class="admin-form__group">
      <label class="admin-form__label" for="division_id">División *</label>
      <div class="nes-select">
        <select id="division_id" name="division_id" required>
          <option value="">Seleccionar...</option>
          {divisiones?.map(d => <option value={d.id}>{d.nombre}</option>)}
        </select>
      </div>
    </div>

    <div class="admin-form__group">
      <label class="admin-form__label" for="nombre">Nombre *</label>
      <input id="nombre" name="nombre" type="text" class="nes-input" required />
    </div>

    <div class="admin-form__group">
      <label class="admin-form__label" for="descripcion">Descripción</label>
      <textarea id="descripcion" name="descripcion" class="nes-textarea" rows="3"></textarea>
    </div>

    <div class="admin-form__group">
      <label class="admin-form__label" for="estado">Estado *</label>
      <div class="nes-select">
        <select id="estado" name="estado" required>
          <option value="idea">Idea</option>
          <option value="en_progreso">En progreso</option>
          <option value="completado">Completado</option>
        </select>
      </div>
    </div>

    <div class="admin-form__group">
      <label class="admin-form__label" for="link">Link</label>
      <input id="link" name="link" type="url" class="nes-input" placeholder="https://..." />
    </div>

    <p id="form-error" style="display:none; font-family:var(--font-pixel); font-size:0.6rem; color:var(--danger);"></p>

    <div class="admin-form__actions">
      <button type="submit" class="btn btn--primary">[ Crear Proyecto ]</button>
      <a href="/dashboard/proyectos" class="btn btn--ghost">Cancelar</a>
    </div>
  </form>

  <script>
    document.getElementById('form-nuevo')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target as HTMLFormElement;
      const errEl = document.getElementById('form-error') as HTMLElement;
      errEl.style.display = 'none';

      const data = new FormData(form);
      const body: Record<string, unknown> = {};
      for (const [k, v] of data.entries()) { body[k] = v || null; }

      const res = await fetch('/api/proyectos', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });

      if (res.ok) {
        window.location.href = '/dashboard/proyectos';
      } else {
        const json = await res.json().catch(() => ({}));
        errEl.textContent = json.error ?? 'Error al crear el proyecto.';
        errEl.style.display = 'block';
      }
    });
  </script>
</AdminLayout>
