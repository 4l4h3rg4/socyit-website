# Variables de entorno — SocyIT Website

# URL de tu proyecto en Supabase (visible en Settings > API)
PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave anónima de Supabase (segura para el browser/cliente)
PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui

# Clave maestra de Supabase (SOLO para el servidor — nunca en el browser)
# La encuentras en Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui

# Link de invitación al grupo de WhatsApp de la comunidad
PUBLIC_WHATSAPP_URL=https://chat.whatsapp.com/tu-link-aqui
