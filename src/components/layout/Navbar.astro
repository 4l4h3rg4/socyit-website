---
// Navbar.astro — Dock flotante en la parte inferior (desktop) + hamburguesa (mobile)
import { Icon } from 'astro-icon/components';
---

<nav class="navbar" id="navbar" aria-label="Navegación principal">
  <!-- DESKTOP: dock flotante -->
  <ul class="navbar__dock" role="list">
    <li>
      <a href="/#hero" class="navbar__item" data-section="hero" aria-label="Inicio">
        <Icon name="lucide:home" class="navbar__icon" />
        <span class="navbar__label">Inicio</span>
      </a>
    </li>
    <li>
      <a href="/#sobre-nosotros" class="navbar__item" data-section="sobre-nosotros" aria-label="Nosotros">
        <Icon name="lucide:users" class="navbar__icon" />
        <span class="navbar__label">Nosotros</span>
      </a>
    </li>
    <li>
      <a href="/branch" class="navbar__item" data-section="divisiones" aria-label="Branch">
        <Icon name="lucide:layers" class="navbar__icon" />
        <span class="navbar__label">Branch</span>
      </a>
    </li>
    <li>
      <a href="/#eventos" class="navbar__item" data-section="eventos" aria-label="Eventos">
        <Icon name="lucide:calendar" class="navbar__icon" />
        <span class="navbar__label">Eventos</span>
      </a>
    </li>
    <li>
      <a href="/#proyectos" class="navbar__item" data-section="proyectos" aria-label="Proyectos">
        <Icon name="lucide:code-2" class="navbar__icon" />
        <span class="navbar__label">Proyectos</span>
      </a>
    </li>
    <li>
      <a href="/#unete" class="navbar__item navbar__item--cta" data-section="unete" aria-label="Únete">
        <Icon name="lucide:rocket" class="navbar__icon" />
        <span class="navbar__label">Únete</span>
      </a>
    </li>
  </ul>

  <!-- MOBILE: botón hamburguesa + menú desplegable -->
  <button class="navbar__hamburger" id="hamburgerBtn" aria-label="Abrir menú" aria-expanded="false">
    <div class="navbar__hamburger-icons">
      <Icon name="lucide:menu" class="icon-menu" />
      <Icon name="lucide:x" class="icon-close" />
    </div>
    <span class="navbar__hamburger-text" id="hamburgerText">Menú</span>
  </button>

  <div class="navbar__mobile-menu" id="mobileMenu" aria-hidden="true">
    <ul role="list">
      <li>
        <a href="/#hero" class="navbar__mobile-item" onclick="closeMenu()">
          <Icon name="lucide:home" class="navbar__mobile-icon" />
          Inicio
        </a>
      </li>
      <li>
        <a href="/#sobre-nosotros" class="navbar__mobile-item" onclick="closeMenu()">
          <Icon name="lucide:users" class="navbar__mobile-icon" />
          Nosotros
        </a>
      </li>
      <li>
        <a href="/branch" class="navbar__mobile-item" onclick="closeMenu()">
          <Icon name="lucide:layers" class="navbar__mobile-icon" />
          Branch
        </a>
      </li>
      <li>
        <a href="/#eventos" class="navbar__mobile-item" onclick="closeMenu()">
          <Icon name="lucide:calendar" class="navbar__mobile-icon" />
          Eventos
        </a>
      </li>
      <li>
        <a href="/#proyectos" class="navbar__mobile-item" onclick="closeMenu()">
          <Icon name="lucide:code-2" class="navbar__mobile-icon" />
          Proyectos
        </a>
      </li>
      <li>
        <a href="/#unete" class="navbar__mobile-item navbar__mobile-item--cta" onclick="closeMenu()">
          <Icon name="lucide:rocket" class="navbar__mobile-icon" />
          Únete
        </a>
      </li>
    </ul>
  </div>
</nav>

<script>
  const navbar = document.getElementById('navbar')!;
  const hamburgerBtn = document.getElementById('hamburgerBtn')!;
  const mobileMenu = document.getElementById('mobileMenu')!;

  // ---- Hide/show on scroll ----
  let lastScrollY = window.scrollY;

  window.addEventListener('scroll', () => {
    const currentScrollY = window.scrollY;
    if (currentScrollY > lastScrollY && currentScrollY > 100) {
      navbar.classList.add('hidden');
    } else {
      navbar.classList.remove('hidden');
    }
    lastScrollY = currentScrollY;
  }, { passive: true });

  // ---- Hamburguesa mobile ----
  hamburgerBtn.addEventListener('click', () => {
    const isOpen = mobileMenu.classList.contains('open');
    mobileMenu.classList.toggle('open', !isOpen);
    hamburgerBtn.classList.toggle('active', !isOpen);
    hamburgerBtn.setAttribute('aria-expanded', String(!isOpen));
    mobileMenu.setAttribute('aria-hidden', String(isOpen));
    document.getElementById('hamburgerText')!.innerText = isOpen ? 'Menú' : 'Cerrar';
  });

  // Cierra el menú mobile desde los links
  (window as any).closeMenu = () => {
    mobileMenu.classList.remove('open');
    hamburgerBtn.classList.remove('active');
    hamburgerBtn.setAttribute('aria-expanded', 'false');
    mobileMenu.setAttribute('aria-hidden', 'true');
    document.getElementById('hamburgerText')!.innerText = 'Menú';
  };

  // ---- Active link highlight (solo en landing) ----
  if (window.location.pathname === '/') {
    const sections = document.querySelectorAll('section[id]');
    const navItems = document.querySelectorAll<HTMLElement>('.navbar__item[data-section]');

    const sectionObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            navItems.forEach((item) => item.classList.remove('active'));
            const active = document.querySelector(`.navbar__item[data-section="${entry.target.id}"]`);
            active?.classList.add('active');
          }
        });
      },
      { threshold: 0.4 }
    );

    sections.forEach((section) => sectionObserver.observe(section));
  }
</script>

<style>
  /* ---- DOCK (desktop) ---- */
  .navbar {
    position: fixed;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 100;
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.35s ease, bottom 0.35s ease;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .navbar.hidden {
    transform: translateX(-50%) translateY(150%);
    opacity: 0;
  }

  .navbar__dock {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    background: rgba(8, 8, 15, 0.9);
    backdrop-filter: blur(16px);
    border: 1px solid var(--border-bright);
    border-radius: 0;
    padding: 0.5rem 0.75rem;
    list-style: none;
    box-shadow: 0 8px 32px rgba(0,0,0,0.7), 0 0 0 1px rgba(99,102,241,0.1);
  }

  .navbar__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    padding: 0.5rem 0.85rem;
    /* min 44×44 px touch target */
    min-height: 44px;
    min-width: 44px;
    justify-content: center;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s, background 0.2s;
    position: relative;
  }

  .navbar__item:hover,
  .navbar__item.active {
    color: var(--primary);
    background: var(--primary-glow-sm);
  }

  .navbar__item--cta {
    color: var(--primary);
    border: 1px solid var(--primary);
    background: var(--primary-glow-sm);
  }

  .navbar__item--cta:hover {
    background: var(--primary-glow);
  }

  /* SVG icon heredado del color del padre */
  .navbar__icon {
    width: 16px;
    height: 16px;
    display: block;
    color: inherit;
    flex-shrink: 0;
  }

  .navbar__label {
    font-family: var(--font-pixel);
    font-size: 0.51rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    white-space: nowrap;
  }

  /* ---- HAMBURGUESA (mobile) ---- */
  .navbar__hamburger {
    display: none;
    flex-direction: row;
    gap: 8px;
    background: rgba(8, 8, 15, 0.85);
    border: 1px solid var(--border-bright, rgba(255,255,255,0.1));
    padding: 0.6rem 1.5rem;
    border-radius: 9999px;
    cursor: pointer;
    position: relative;
    z-index: 101;
    min-height: 48px;
    align-items: center;
    justify-content: center;
    box-shadow: 0 8px 32px rgba(0,0,0,0.7), 0 0 0 1px rgba(99,102,241,0.15);
    backdrop-filter: blur(16px);
    transition: all 0.3s ease;
  }

  .navbar__hamburger:active {
    transform: scale(0.95);
  }

  .navbar__hamburger-icons {
    position: relative;
    width: 18px;
    height: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--primary);
  }
  
  .navbar__hamburger-icons svg {
    position: absolute;
    width: 100%;
    height: 100%;
    transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s ease;
  }
  
  .icon-close {
    opacity: 0;
    transform: rotate(-90deg) scale(0.5);
  }
  
  .navbar__hamburger.active .icon-menu {
    opacity: 0;
    transform: rotate(90deg) scale(0.5);
  }
  
  .navbar__hamburger.active .icon-close {
    opacity: 1;
    transform: rotate(0deg) scale(1);
  }

  .navbar__hamburger-text {
    font-family: var(--font-pixel);
    font-size: 0.55rem;
    color: var(--text, #fff);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding-top: 2px;
  }

  .navbar__mobile-menu {
    display: flex;
    flex-direction: column;
    position: absolute;
    bottom: 100%;
    margin-bottom: 1.2rem;
    left: 50%;
    transform: translateX(-50%) translateY(20px) scale(0.95);
    pointer-events: none;
    opacity: 0;
    background: rgba(12, 12, 20, 0.95);
    border: 1px solid var(--border-bright, rgba(255,255,255,0.1));
    backdrop-filter: blur(16px);
    z-index: 100;
    width: 85vw;
    max-width: 340px;
    border-radius: 16px;
    box-shadow: 0 12px 48px rgba(0,0,0,0.8), 0 0 0 1px rgba(99,102,241,0.2);
    transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    transform-origin: bottom center;
  }

  .navbar__mobile-menu.open {
    transform: translateX(-50%) translateY(0) scale(1);
    pointer-events: auto;
    opacity: 1;
  }

  .navbar__mobile-menu ul {
    list-style: none;
    padding: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin: 0;
  }

  .navbar__mobile-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.85rem 1.25rem;
    min-height: 48px;
    font-family: var(--font-pixel);
    font-size: 0.65rem;
    color: var(--text-muted);
    text-decoration: none;
    transition: all 0.2s;
    border-radius: 10px;
  }

  .navbar__mobile-item:hover, .navbar__mobile-item:active {
    color: var(--primary);
    background: var(--primary-glow-sm);
    transform: translateX(5px);
  }

  .navbar__mobile-item--cta {
    color: var(--primary);
    background: rgba(99, 102, 241, 0.05);
    border: 1px solid rgba(99, 102, 241, 0.2);
    margin-top: 0.25rem;
  }

  .navbar__mobile-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    color: inherit;
  }

  /* ---- RESPONSIVE ---- */
  @media (max-width: 640px) {
    .navbar__dock      { display: none; }
    .navbar__hamburger { display: flex; }
  }
</style>
