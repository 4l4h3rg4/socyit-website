---
// Divisiones.astro — Grid de branches en el landing

import { Icon } from 'astro-icon/components';
import { supabase } from '../../lib/supabase';

const { data } = await supabase
  .from('divisiones')
  .select('nombre, descripcion_corta, color_hex, slug')
  .eq('activa', true)
  .order('orden', { ascending: true });

// color_hex → clase CSS (para colores y estilos)
const colorMap: Record<string, string> = {
  '#06b6d4': 'robotica',
  '#ef4444': 'ciber',
  '#7c3aed': 'software',
  '#f59e0b': 'videojuegos',
  '#10b981': 'ia',
  '#f97316': 'redes',
};

// clase CSS → ícono Lucide
const iconMap: Record<string, string> = {
  'robotica':    'lucide:cpu',
  'ciber':       'lucide:shield',
  'software':    'lucide:code-2',
  'videojuegos': 'lucide:gamepad-2',
  'ia':          'lucide:brain',
  'redes':       'lucide:network',
};

const divisiones = (data ?? []).map((d) => ({
  ...d,
  colorClass: colorMap[d.color_hex] ?? 'robotica',
  iconName:   iconMap[colorMap[d.color_hex] ?? 'robotica'] ?? 'lucide:layers',
}));
---

<section id="divisiones" class="divisiones">
  <div class="container">

    <!-- Header -->
    <div class="divisiones__header reveal">
      <div class="divisiones__header-left">
        <span class="section-tag">// BRANCHES</span>
        <h2 class="divisiones__title">&gt; Branches_</h2>
      </div>
      <a href="/branch" class="divisiones__link">
        Ver todas →
      </a>
    </div>

    <!-- Subtítulo explicativo -->
    <p class="divisiones__sub reveal">
      No tienes que elegir una sola. Puedes estar en todas las que quieras — sin restricciones.<br>
      Participa, pide consejos, colabora y aprende en cualquier branch, cuando quieras.
    </p>

    <!-- Grid de branches -->
    <div class="divisiones__grid">
      {divisiones.map((div) => (
        <a
          href={`/branch/${div.slug}`}
          class={`branch-item branch-item--${div.colorClass}`}
          style={`--bc: var(--${div.colorClass})`}
          aria-label={`Branch ${div.nombre}`}
        >
          <div class="branch-item__top">
            <div class="branch-item__icon-wrap">
              <Icon name={div.iconName} class="branch-item__icon" />
            </div>
            <span class="branch-item__name">{div.nombre}</span>
          </div>
          <p class="branch-item__desc">{div.descripcion_corta}</p>
          <span class="branch-item__cta">
            Explorar
            <Icon name="lucide:arrow-right" class="branch-item__arrow" />
          </span>
        </a>
      ))}
    </div>

  </div>
</section>

<script>
  import { gsap, ScrollTrigger, withMotion } from '../../lib/gsap';

  withMotion(() => {
    gsap.set('.branch-item', { autoAlpha: 0, y: 30 });

    ScrollTrigger.create({
      trigger: '.divisiones__grid',
      start: 'top 82%',
      once: true,
      onEnter: () => {
        gsap.to('.branch-item', {
          autoAlpha: 1,
          y: 0,
          stagger: 0.08,
          duration: 0.5,
          ease: 'power2.out',
        });
      },
    });
  });
</script>

<style>
  .divisiones {
    position: relative;
    z-index: 10;
  }

  /* ---- Header ---- */
  .divisiones__header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .divisiones__title {
    font-family: var(--font-pixel);
    font-size: clamp(1.08rem, 2.5vw, 1.2rem);
    margin-top: 0.25rem;
  }

  .divisiones__link {
    font-family: var(--font-pixel);
    font-size: 0.85rem;
    color: var(--primary);
    text-decoration: none;
    transition: color 0.2s;
    white-space: nowrap;
  }

  .divisiones__link:hover { color: var(--text); }

  /* ---- Subtítulo ---- */
  .divisiones__sub {
    font-family: var(--font-mono);
    font-size: 1.19rem;
    color: var(--text-muted);
    line-height: 1.75;
    margin-bottom: 2rem;
    max-width: 600px;
  }

  /* ---- Grid ---- */
  .divisiones__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  /* ---- Branch card ---- */
  .branch-item {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    background: var(--bg-card);
    border: 2px solid var(--border);
    border-top: 3px solid var(--bc);
    padding: 1.25rem;
    text-decoration: none;
    color: inherit;
    position: relative;
    overflow: hidden;
    transition: background 0.2s, border-color 0.2s, transform 0.2s;
  }

  .branch-item::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--bc);
    opacity: 0;
    transition: opacity 0.2s;
    pointer-events: none;
  }

  .branch-item:hover {
    background: var(--bg-card-hover);
    border-color: var(--bc);
    transform: translateY(-2px);
  }

  .branch-item:hover::before { opacity: 0.04; }

  /* Top row: icon + name */
  .branch-item__top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .branch-item__icon-wrap {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: color-mix(in srgb, var(--bc) 15%, var(--bg-card));
    border: 2px solid color-mix(in srgb, var(--bc) 40%, transparent);
  }

  .branch-item__icon {
    width: 20px;
    height: 20px;
    color: var(--bc);
    flex-shrink: 0;
  }

  .branch-item__name {
    font-family: var(--font-pixel);
    font-size: clamp(0.61rem, 1.2vw, 0.81rem);
    color: var(--bc);
    line-height: 1.5;
  }

  /* Description */
  .branch-item__desc {
    font-family: var(--font-mono);
    font-size: 1.05rem;
    color: var(--text-muted);
    line-height: 1.65;
    flex: 1;
  }

  /* CTA row */
  .branch-item__cta {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-pixel);
    font-size: 0.54rem;
    color: var(--bc);
    opacity: 0.7;
    transition: opacity 0.2s, gap 0.2s;
    margin-top: auto;
  }

  .branch-item:hover .branch-item__cta {
    opacity: 1;
    gap: 0.55rem;
  }

  .branch-item__arrow {
    width: 12px;
    height: 12px;
    transition: transform 0.2s;
  }

  .branch-item:hover .branch-item__arrow {
    transform: translateX(3px);
  }

  /* ---- Responsive ---- */
  @media (max-width: 640px) {
    .divisiones__grid {
      grid-template-columns: 1fr;
    }
  }

  @media (min-width: 900px) {
    .divisiones__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
