---
// pages/404.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import StarBackground from '../components/ui/StarBackground.astro';
import Navbar from '../components/layout/Navbar.astro';

export const prerender = true;
---

<BaseLayout title="404 — Página no encontrada | SocyIT">
  <StarBackground />
  <Navbar />

  <main class="not-found">
    <div class="not-found__inner">
      <div class="not-found__window pixel-window" style="max-width: 560px; margin-inline: auto;">
        <div class="pixel-window__bar">
          <div class="pixel-window__dots">
            <div class="pixel-window__dot pixel-window__dot--red"></div>
            <div class="pixel-window__dot pixel-window__dot--yellow"></div>
            <div class="pixel-window__dot pixel-window__dot--green"></div>
          </div>
          <span class="pixel-window__title">error.log</span>
        </div>

        <div class="pixel-window__body not-found__body">
          <p class="not-found__code">4<span style="color:var(--ciber)">0</span>4</p>
          <h1 class="not-found__title">&gt; Página no encontrada_</h1>

          <div class="not-found__log">
            <p><span style="color:var(--primary)">$ </span>cd <span style="color:var(--ciber)">ruta-desconocida</span></p>
            <p style="color:var(--ciber)">ERROR: directorio no existe en este universo.</p>
            <p><span style="color:var(--primary)">$ </span>suggest --fix</p>
            <p style="color:#22c55e">⟶ Volvé a la base de operaciones.</p>
          </div>

          <a href="/" class="pixel-btn not-found__btn">
            &gt; Volver al inicio_
          </a>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .not-found {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 10;
    padding: 2rem;
  }

  .not-found__inner {
    width: 100%;
  }

  .not-found__body {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    text-align: center;
    padding: 2.5rem 2rem;
  }

  .not-found__code {
    font-family: var(--font-pixel);
    font-size: clamp(3rem, 10vw, 6rem);
    color: var(--text-dim);
    line-height: 1;
  }

  .not-found__title {
    font-family: var(--font-pixel);
    font-size: clamp(0.6rem, 2vw, 0.9rem);
    color: var(--text);
    line-height: 1.6;
  }

  .not-found__log {
    text-align: left;
    width: 100%;
    background: var(--bg);
    border: 1px solid var(--border);
    padding: 1rem 1.25rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-muted);
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .not-found__btn {
    margin-top: 0.5rem;
  }
</style>
